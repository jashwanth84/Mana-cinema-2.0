<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Overall Dark Semi-transparent Base for contrast -->
    <path
        android:fillColor="#121217"
        android:pathData="M 0 0 h 108 v 108 h -108 z" />

    <!-- Group of coordinates shifted/centered -->
    <group
        android:translateX="0"
        android:translateY="0">

        <!-- 1. Left stem (Film strip stem of M) plus Diagonal connection and Right Camera Body combined -->
        <!-- Doing them with glossy crimson-red gradient -->
        <path
            android:strokeLineJoin="round"
            android:strokeLineCap="round"
            android:pathData="M 12 18 h 14 v 22 L 60 82 H 44 Z">
            <aapt:attr name="android:fillColor">
                <gradient
                    android:startX="12"
                    android:startY="18"
                    android:endX="60"
                    android:endY="82"
                    android:type="linear">
                    <item android:offset="0.0" android:color="#FF3B30"/>
                    <item android:offset="0.4" android:color="#E50914"/>
                    <item android:offset="1.0" android:color="#800010"/>
                </gradient>
            </aapt:attr>
        </path>

        <!-- Left vertical stem extension to make sure it is solid -->
        <path
            android:pathData="M 12 18 H 26 V 82 H 12 Z">
            <aapt:attr name="android:fillColor">
                <gradient
                    android:startX="12"
                    android:startY="18"
                    android:endX="12"
                    android:endY="82"
                    android:type="linear">
                    <item android:offset="0.0" android:color="#FF3B30"/>
                    <item android:offset="0.5" android:color="#D31027"/>
                    <item android:offset="1.0" android:color="#7F0C1B"/>
                </gradient>
            </aapt:attr>
        </path>

        <!-- Right Video Camera Body & Connector -->
        <path
            android:pathData="M 54 30 L 78 18 H 82 v 64 H 48 L 54 74 Z">
            <aapt:attr name="android:fillColor">
                <gradient
                    android:startX="48"
                    android:startY="18"
                    android:endX="82"
                    android:endY="82"
                    android:type="linear">
                    <item android:offset="0.0" android:color="#FF3B30"/>
                    <item android:offset="0.5" android:color="#D31027"/>
                    <item android:offset="1.0" android:color="#7F0C1B"/>
                </gradient>
            </aapt:attr>
        </path>

        <!-- 2. The Film strip negative square spaces over the Left Stem -->
        <!-- Drawn with matching background color to act as transparent punches -->
        <path android:fillColor="#121217" android:pathData="M 15 22 h 5 v 4 h -5 z" />
        <path android:fillColor="#121217" android:pathData="M 15 29 h 5 v 4 h -5 z" />
        <path android:fillColor="#121217" android:pathData="M 15 36 h 5 v 4 h -5 z" />
        <path android:fillColor="#121217" android:pathData="M 15 43 h 5 v 4 h -5 z" />
        <path android:fillColor="#121217" android:pathData="M 15 50 h 5 v 4 h -5 z" />
        <path android:fillColor="#121217" android:pathData="M 15 57 h 5 v 4 h -5 z" />
        <path android:fillColor="#121217" android:pathData="M 15 64 h 5 v 4 h -5 z" />
        <path android:fillColor="#121217" android:pathData="M 15 71 h 5 v 4 h -5 z" />
        <path android:fillColor="#121217" android:pathData="M 15 78 h 5 v 4 h -5 z" />

        <!-- 3. Camera Lens Hood (Triangle on the right) -->
        <path
            android:pathData="M 82 44 L 96 32 V 68 L 82 56 Z">
            <aapt:attr name="android:fillColor">
                <gradient
                    android:startX="82"
                    android:startY="32"
                    android:endX="96"
                    android:endY="68"
                    android:type="linear">
                    <item android:offset="0.0" android:color="#FF3B30"/>
                    <item android:offset="1.0" android:color="#9E0A1D"/>
                </gradient>
            </aapt:attr>
        </path>

        <!-- 4. Camera Lens details (Concentric metallic/glass rings overlaying right body) -->
        <!-- Center of lens at around x=68, y=50 -->
        <!-- Outer Dark Ring -->
        <path
            android:fillColor="#25252D"
            android:pathData="M 68 28 A 22 22 0 1 1 67.99 28 Z" />

        <!-- Silver Shiny Metal Bezel Line -->
        <path
            android:strokeColor="#C0C0C0"
            android:strokeWidth="1.2"
            android:fillColor="#1D1D24"
            android:pathData="M 68 31 A 19 19 0 1 1 67.99 31 Z" />

        <!-- Deep Dark Lens Body -->
        <path
            android:fillColor="#0A0A0F"
            android:pathData="M 68 34 A 16 16 0 1 1 67.99 34 Z" />

        <!-- Lens Aperture Reflections - Gorgeous glowing red core -->
        <path
            android:pathData="M 68 40 A 10 10 0 1 1 67.99 40 Z">
            <aapt:attr name="android:fillColor">
                <gradient
                    android:startX="58"
                    android:startY="40"
                    android:endX="78"
                    android:endY="60"
                    android:type="radial"
                    android:gradientRadius="10">
                    <item android:offset="0.0" android:color="#FF5C5C"/>
                    <item android:offset="0.6" android:color="#D31027"/>
                    <item android:offset="1.0" android:color="#210004"/>
                </gradient>
            </aapt:attr>
        </path>

        <!-- Secondary glass lens reflection (Red iris) -->
        <path
            android:fillColor="#4DFF003C"
            android:pathData="M 68 44 A 6 6 0 1 1 67.99 44 Z" />

        <!-- Main bright reflection (Soft white lens flare/glint) -->
        <path
            android:fillColor="#B7FFFFFF"
            android:pathData="M 72 45 A 2 2 0 1 1 71.99 45 Z" />
    </group>

    <!-- 5. Sleek Movie Pro Typography underneath the logo elements -->
    <!-- Positioned elegantly at the lower portion -->
    <group
        android:translateX="0"
        android:translateY="88">
        <!-- Horizontal red/metallic dividers flanking the 'PRO' area -->
        <path
            android:pathData="M 22 10 H 38 M 70 10 H 86"
            android:strokeColor="#FF2323"
            android:strokeWidth="1.5"
            android:strokeLineCap="round" />
        
        <!-- We can display custom glowing elements representing the "PRO" aesthetic -->
        <path
            android:fillColor="#FF2323"
            android:pathData="M 50 7 h 8 v 6 h -8 z" />
    </group>
</vector>
